---
const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};
---

<div class="ch-hero">
	<h1 class="ch-title" id="_top" data-page-title set:html={title} />
	{tagline && <p class="ch-tagline">{tagline}</p>}
	{actions.length > 0 && (
		<div class="ch-actions">
			{actions.map(({ text, link: href, variant }) => {
				const external = href.startsWith('http');
				return (
					<a
						href={href}
						class={`ch-btn ch-btn-${variant ?? 'secondary'}`}
						{...(external ? { target: '_blank', rel: 'noopener' } : {})}
					>
						{text}
					</a>
				);
			})}
		</div>
	)}
</div>

<style>
	.ch-hero {
		padding: 5rem 1.5rem 4.5rem;
		text-align: center;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.ch-title {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.08;
		color: var(--sl-color-white);
		margin: 0 auto 1.25rem;
		max-width: 700px;
	}

	.ch-tagline {
		font-size: 1.0625rem;
		color: var(--sl-color-gray-3);
		max-width: 500px;
		margin: 0 auto 2.5rem;
		line-height: 1.65;
	}

	.ch-actions {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.ch-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.375rem;
		border-radius: 0.5rem;
		font-size: 0.9375rem;
		text-decoration: none;
		transition: opacity 0.15s, border-color 0.15s, color 0.15s;
	}

	.ch-btn-primary {
		background: var(--sl-color-accent);
		color: #fff;
		font-weight: 600;
	}

	.ch-btn-primary:hover {
		opacity: 0.88;
		color: #fff;
	}

	.ch-btn-minimal,
	.ch-btn-secondary {
		border: 1px solid var(--sl-color-gray-5);
		background: transparent;
		color: var(--sl-color-gray-2);
		font-weight: 500;
	}

	.ch-btn-minimal:hover,
	.ch-btn-secondary:hover {
		border-color: var(--sl-color-accent);
		color: var(--sl-color-accent);
	}
</style>
